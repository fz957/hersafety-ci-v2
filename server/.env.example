# ============================================================
# HerSafety CI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hersafety

# JWT
JWT_SECRET=CHANGE_ME_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_another_strong_random_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic Claude IA
ANTHROPIC_API_KEY=sk-ant-...

# Africa's Talking SMS
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# Mode application
# development : SMS sandbox, appels simulés, badge MODE TEST
# production  : tout est réel
APP_MODE=development

# URLs
APP_URL=http://localhost:3000
PORT=5000
FRONTEND_URL=http://localhost:5173

# Node
NODE_ENV=development
