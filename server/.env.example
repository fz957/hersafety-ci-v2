# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hersafety

# JWT
JWT_SECRET=your-secret-key-min-32-chars-changeme
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-changeme
JWT_EXPIRES_IN=24h

# Node
NODE_ENV=development
APP_MODE=development
PORT=5001

# URLs
APP_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173

# Email Service (choose one: gmail, sendgrid, mailtrap)
EMAIL_PROVIDER=gmail
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-gmail-app-password

# AI Services
GROQ_API_KEY=your-groq-api-key  # Required for Lyra chat assistant
ANTHROPIC_API_KEY=your-anthropic-key  # Optional fallback

# SMS (Optional)
AFRICASTALKING_API_KEY=your-africa-talking-key
AFRICASTALKING_USERNAME=your-africa-talking-username

# Firebase Cloud Messaging (Optional - currently disabled)
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# FIREBASE_PROJECT_ID=your-firebase-project-id
