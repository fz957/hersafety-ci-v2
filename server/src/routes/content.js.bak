const express = require('express');
const Joi     = require('joi');
const { v4: uuidv4 } = require('uuid');

const knex              = require('../db/knex');
const { requireAuth }   = require('../middlewares/auth');

const router = express.Router();
router.use(requireAuth);

const DANGER_TYPES = ['harcelement_verbal', 'agression_physique', 'agression_sexuelle', 'vol', 'suivi', 'detour_force', 'autre'];

// ─── GET /api/articles ────────────────────────────────────────────────────────

router.get('/articles', async (req, res) => {
  try {
    const articles = await knex('articles')
      .where({ organization_id: req.user.status: 'pending' })
      .select('*')
      .orderBy('created_at', 'desc')
      .limit(100);

    return res.json({ success: true, data: articles });
  } catch (err) {
    console.error('Error fetching articles:', err);
    return res.status(500).json({ success: false, error: 'Erreur récupération articles' });
  }
});

// ─── GET /api/photos ──────────────────────────────────────────────────────────

router.get('/photos', async (req, res) => {
  try {
    const photos = await knex('photos')
      .where({ organization_id: req.user.status: 'pending' })
      .select('*')
      .orderBy('created_at', 'desc')
