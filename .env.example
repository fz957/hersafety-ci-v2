# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hersafety

# ─── JWT Authentication ───────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRES_IN=24h

# ─── Application ──────────────────────────────────────────────
APP_MODE=development
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
PORT=5000

# ─── Firebase Cloud Messaging ─────────────────────────────────
# Pour les notifications push
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=safety-510e8

# Frontend Firebase keys (publiques, safe)
VITE_FIREBASE_API_KEY=AIzaSyDC3YKr5AKsDWNByyFzuiAWIgt-CD41Qn4
VITE_FIREBASE_AUTH_DOMAIN=safety-510e8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=safety-510e8
VITE_FIREBASE_STORAGE_BUCKET=safety-510e8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=872821982195
VITE_FIREBASE_APP_ID=1:872821982195:web:23b320a62b99e2eba2c886
VITE_FIREBASE_VAPID_KEY=your_vapid_key_from_firebase_console

# ─── Email Service ────────────────────────────────────────────
# Option 1: Gmail
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@hersafety.ci

# Option 2: SendGrid
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=noreply@hersafety.ci

# Option 3: Mailtrap (pour dev/test)
# EMAIL_PROVIDER=mailtrap
# MAILTRAP_USER=your_mailtrap_user
# MAILTRAP_PASSWORD=your_mailtrap_password
# EMAIL_FROM=noreply@hersafety.ci

# Option 4: Generic SMTP
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@hersafety.ci

# ─── SMS Service (Africa's Talking) - OPTIONNEL ────────────────
# Requis si tu veux envoyer des SMS (payant)
# AFRICASTALKING_API_KEY=your_api_key
# AFRICASTALKING_USERNAME=your_username

